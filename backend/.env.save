# Update your backend to use sample data without TMDB
cd ~/netflix/deepseek/netflix-clone

cat > backend/.env << 'EOF'
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/netflix-clone
JWT_SECRET=netflix-clone-dev-secret-key-2026
TMDB_API_KEY=test_key_use_sample_data
FRONTEND_URL=http://localhost:3000
USE_SAMPLE_DATA=true
EOFNODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/netflix-clone
JWT_SECRET=your-super-secret-jwt-key-change-this
TMDB_API_KEY=your_tmdb_api_key_here
FRONTEND_URL=http://localhost:3000
